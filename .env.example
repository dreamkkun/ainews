# .env.example — 실제 사용 시 이 파일을 복사해 .env 로 저장 후 값 입력

# ── Anthropic API (AI 분석 엔진) ──────────────────────────────
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력

# ── 네이버 개발자 API (뉴스 수집) ────────────────────────────
# 발급: https://developers.naver.com/apps/#/register
# 검색 API 선택 → 무료 일 25,000건
NAVER_CLIENT_ID=여기에_클라이언트_ID_입력
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿_입력

# ── DB 파일 경로 (선택 사항) ──────────────────────────────────
# 기본값: 현재 디렉터리의 news.db
# DB_PATH=./news.db
